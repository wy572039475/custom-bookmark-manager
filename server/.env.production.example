# ============================================
# 生产环境配置模板
# Production Environment Configuration
# ============================================
# 使用方法：
# 1. 复制此文件为 .env.production
# 2. 填写真实的配置值
# 3. 部署时通过 docker-compose 或环境变量注入

# Server Configuration
# ------------------------------
PORT=3001
NODE_ENV=production

# Database - Turso (SQLite) Configuration
# ------------------------------
# 获取方式：访问 https://turso.tech 创建免费数据库
# 1. 注册 Turso 账号
# 2. 创建数据库: turso db create bookmark-db
# 3. 获取数据库 URL: turso db show bookmark-db
# 4. 创建 Auth Token: turso auth token create

TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-production-auth-token-here

# JWT Configuration
# ------------------------------
# ⚠️ 生产环境必须使用强随机密钥（至少32位）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-production-jwt-secret-at-least-64-chars
JWT_EXPIRES_IN=7d

# CORS Configuration
# ------------------------------
# ⚠️ 生产环境必须设置为实际的前端域名
# 多个域名用逗号分隔
# 示例：https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# Optional: Rate Limiting
# ------------------------------
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
