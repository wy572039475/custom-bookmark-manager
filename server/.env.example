# Server Configuration
PORT=3001
NODE_ENV=development

# Storage Type: sqlite (Turso/本地) or postgres
STORAGE_TYPE=sqlite

# Database - Turso (SQLite) Configuration
# 获取方式：访问 https://turso.tech 创建免费数据库
# 1. 注册 Turso 账号
# 2. 创建数据库: turso db create bookmark-db
# 3. 获取数据库 URL: turso db show bookmark-db
# 4. 创建 Auth Token: turso auth token create
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# 本地开发模式（可选，不使用 Turso 云数据库)
# 如果设置为 file:./local.db，则使用本地 SQLite 数据库
# TURSO_DATABASE_URL=file:./local.db
# TURSO_AUTH_TOKEN=

# CORS - 开发环境允许所有源，生产环境请配置你的前端域名
# 多个域名用逗号分隔，例如：https://example.com,https://www.example.com
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
# 生成安全密钥: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 生产环境务必修改此密钥，不要使用默认值！
JWT_SECRET=your-secure-random-secret-key-here
JWT_EXPIRES_IN=7d
